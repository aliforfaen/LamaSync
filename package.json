{
  "name": "lamasync",
  "version": "0.2.2",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:server": "bun run --watch packages/server/src/index.ts",
    "dev:daemon": "bun run packages/daemon/src/index.ts",
    "dev:tui": "bun run packages/tui/src/index.ts",
    "dev:web-ui": "bun run --filter @lamasync/web-ui dev",
    "build:web-ui": "bun run --filter @lamasync/web-ui build",
    "build": "bun scripts/gen-version.ts && bun run --filter @lamasync/web-ui build && bun run --filter '!@lamasync/web-ui' build",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0"
  }
}
