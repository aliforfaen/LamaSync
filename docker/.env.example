# Copy this file to docker/.env and fill in real values.
# `docker compose --env-file docker/.env up` will read from it.

LAMASYNC_API_KEY=please-change-me-to-a-long-random-string

# Optional: override the image used by docker-compose. Defaults to GHCR latest.
# LAMASYNC_IMAGE=ghcr.io/aliforfaen/lamasync-server:latest

# Optional: host IP to bind the published port to. Use 127.0.0.1 for local-only
# testing or 0.0.0.0 to expose on all interfaces (needed for Tailscale/LAN).
# LAMASYNC_HOST_IP=0.0.0.0

# Optional: tailnet IP for the server host. Used in the agent skill and TUI defaults.
# LAMASYNC_TAILNET_IP=100.64.0.1
