# Copy this file to docker/.env.test and generate fresh secrets.
# This key is used only for the local Docker dogfood test stack.

LAMASYNC_API_KEY=<generate with openssl rand -hex 32>
LAMASYNC_MINIO_ROOT_USER=<minio-username>
LAMASYNC_MINIO_ROOT_PASSWORD=<minio-password>
LAMASYNC_MINIO_BUCKET=lamasync-test
